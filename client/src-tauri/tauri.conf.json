{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "voicechats",
  "version": "0.1.0",
  "identifier": "dev.jangjunha.voicechats",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "voicechats",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
